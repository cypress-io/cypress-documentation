{
  "name": "cypress-docusaurus-ts",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "postinstall": "patch-package",
    "prestart": "node ./scripts/checkRemarkPluginsBuild.js",
    "start": "docusaurus start",
    "prebuild": "rm -rf dist && npm run build:plugins",
    "build": "docusaurus build --out-dir dist",
    "build:plugins": "npm --prefix ./plugins/cypressRemarkPlugins run build && npm --prefix ./plugins/llm run build",
    "lint": "npm run lint:markdown && npm run lint:frontmatter",
    "lint:fix": "npm run lint:markdown:fix && npm run lint:frontmatter:fix",
    "lint:markdown": "prettier --check '**/*.{md,mdx}'",
    "lint:markdown:fix": "prettier --write '**/*.{md,mdx}'",
    "lint:frontmatter": "node scripts/lint-frontmatter.js",
    "lint:frontmatter:fix": "node scripts/lint-frontmatter.js --fix",
    "enrich:plugins": "node ./scripts/enrich-plugins.mjs",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "preserve": "npm run build:plugins",
    "serve": "docusaurus serve --dir dist",
    "test": "cypress run",
    "test:plugins": "npm --prefix ./plugins/cypressRemarkPlugins run test && npm --prefix ./plugins/llm run test && npm run test:faq-plugin",
    "test:faq-plugin": "vitest run plugins/faq-structured-data.test.js",
    "test:search": "vitest run src/theme/SearchBar/searchRanking.test.js scripts/search/algolia-client.test.mjs scripts/search/scrape-and-compare-algolia-index.test.mjs",
    "preview:og": "node scripts/preview-og-cards.js",
    "test:titles": "npm run build && node scripts/test-titles.js",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "prepare": "husky"
  },
  "dependencies": {
    "@cypress-design/css": "^1.3.0",
    "@cypress-design/react-accordion": "^1.1.0",
    "@cypress-design/react-button": "^1.0.1",
    "@cypress-design/react-docmenu": "^1.0.2",
    "@cypress-design/react-tag": "^1.0.3",
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "@fortawesome/fontawesome-svg-core": "^6.5.1",
    "@fortawesome/free-brands-svg-icons": "^6.5.1",
    "@fortawesome/free-solid-svg-icons": "^6.5.1",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@mdx-js/react": "^3.0.0",
    "autoprefixer": "^10.5.2",
    "clsx": "^2.1.0",
    "docusaurus-plugin-image-zoom": "^2.0.0",
    "docusaurus-plugin-sass": "0.2.6",
    "postcss": "^8.5.16",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remark-directive": "^3.0.0",
    "sass": "^1.101.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@prettier/sync": "^0.6.1",
    "@types/turndown": "^5.0.6",
    "cypress": "^15.18.0",
    "got": "^15.1.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "node-fetch": "^3.3.2",
    "p-map": "^7.0.5",
    "patch-package": "^8.0.0",
    "prettier": "^3.9.4",
    "sanitize-html": "^2.17.5",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "1.0.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "**/*.{md,mdx}": "prettier --write"
  }
}
